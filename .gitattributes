# Git 属性配置

# 文本文件标准化行尾
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.env.example text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# 脚本文件保持可执行权限
*.sh text eol=lf
Makefile text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.pt binary
*.pth binary
*.bin binary
*.db binary
*.sqlite binary

# DICOM 医学影像
*.dcm binary
*.dicom binary

# 归档文件
*.zip binary
*.tar binary
*.gz binary

# 锁定文件
package-lock.json text eol=lf
poetry.lock text eol=lf

# 文档
*.rst text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# 配置文件
*.ini text eol=lf
*.cfg text eol=lf
*.toml text eol=lf

# 特殊文件
LICENSE text eol=lf
README* text eol=lf
CHANGELOG* text eol=lf
CONTRIBUTING* text eol=lf
SECURITY* text eol=lf
CODE_OF_CONDUCT* text eol=lf
