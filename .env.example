# ==================== 阿里云百炼 API ====================
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=true
# 生产环境请指定具体域名，多个用逗号分隔
ALLOWED_ORIGINS=*

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite+aiosqlite:///./aimed.db

# ==================== JWT 认证配置 ====================
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ==================== 诊断配置 ====================
STOMACH_MODEL_PATH=models/stomach_v1.pt
PANCREAS_MODEL_PATH=models/pancreas_v1.pt
DIAGNOSIS_TIMEOUT=30
MAX_IMAGE_SIZE_MB=10

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/aimed.log
